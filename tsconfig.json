{
  "extends": "astro/tsconfigs/strictest",
  "include": [".astro/types.d.ts", "**/*", "./worker-configuration.d.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["unplugin-icons/types/astro"],
    "jsx": "preserve"
  }
}
