---
import { getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { BlogPosts, BlogPost } from '@rimelight/ui/nuxt';

const posts = (await getCollection('blog')).toSorted(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<AppLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<style slot="head">
		main {
			width: 960px;
		}
		.blog-section {
			padding: 2rem 0;
		}
	</style>

	<main>
		<section class="blog-section">
			<BlogPosts client:load>
				{
					posts.map((post, index) => (
						<BlogPost
							client:load
							title={post.data.title}
							description={post.data.description}
							date={post.data.pubDate}
							image={post.data.heroImage}
							to={`/blog/${post.id}/`}
							variant="ghost"
							ui={index === 0 ? {
								root: 'col-span-full flex flex-col items-center text-center gap-6 mb-8',
								header: 'w-full aspect-[21/9]',
								title: 'text-4xl lg:text-6xl font-bold',
								description: 'text-xl max-w-2xl mx-auto'
							} : {}}
						/>
					))
				}
			</BlogPosts>
		</section>
	</main>
</AppLayout>
